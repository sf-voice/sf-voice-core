# root-level env, loaded automatically by mise.toml when you cd into this
# repo (or run a `mise run …` task). copy to `.env` and tweak as needed.
#
# `.env` itself is gitignored — only this template is checked in.
#
# `.env` is the single source of truth: every app + every task reads
# from here. dynamic values (e.g. NGROK_URL written by `mise run dev`)
# get appended to this same file so they survive across terminals.

# ── ports ────────────────────────────────────────────────────────────────
# each Phoenix app reads its own port from here so the two apps can run
# side-by-side from a single shell without colliding.
RESTO_BOOKING_APP_PORT=4000
ELLIE_AI_PORT=4321

# ── shared bearer between resto and ellie ────────────────────────────────
# resto's /api/* requires this; ellie sends it on every outbound call.
# anything non-empty works in dev — generate something random for prod.
INTERNAL_API_TOKEN=dev-internal-api-token-not-for-prod

# ── third-party keys (placeholders — fill in as ellie_ai comes online) ───
# OPENAI_API_KEY=sk-...
# TELNYX_API_KEY=KEY...
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-west-1

# ── telnyx phone number (E.164, used by seeds.exs) ───────────────────────
# the single number ellie answers in dev. the seed assigns it to the
# canonical org (seasons-sf); the other seeded locations exist without
# a number for switcher demos and get one assigned manually via
# Settings → Phone & integrations as you provision more.
# PHONE_NUMBER=+18774980043

# ── core stack: rust api + dev data layer ────────────────────────────────
# DATABASE_URL is the canonical name sqlx/diesel/sea-orm read by default.
# format must match infra/dev/docker-compose.yml defaults (or whatever you
# override there via MYSQL_USER / MYSQL_PASSWORD / MYSQL_DATABASE).
DATABASE_URL=mysql://sf_voice:sf_voice@127.0.0.1:3306/sf_voice_dev

# duckdb is embedded (no server, no port). the rust api opens this file
# directly via the `duckdb` crate. relative paths resolve from the
# working dir cargo runs in — root of the repo for `mise run core:dev`.
# the file is created on first write; `mise run install` ensures the
# parent directory exists.
DUCKDB_PATH=./data/sf_voice.duckdb

# ── debugging product pipeline (phase C onwards) ─────────────────────────
# whisper (asr) — openai hosted, whisper-large-v3. embeddings reuse the
# same key (text-embedding-3-small).
# OPENAI_API_KEY=sk-...
#
# diarization endpoint — pyannote-3.1 via huggingface inference, or
# self-hosted equivalent. http POST audio, returns speaker turns.
# DIARIZE_URL=https://api-inference.huggingface.co/models/pyannote/speaker-diarization-3.1
#
# end-of-turn vad — internal service. reuse candidate:
# apps/ellie_ai/lib/ellie_ai/calls/vad_gate.ex exposed over http.
# EOT_VAD_URL=http://127.0.0.1:4321/api/vad/eot
#
# fixed org for the demo. real per-customer auth is in core/TODO.md.
# the seed at infra/dev/seed-demo.sql writes this same uuid into orgs.id.
SF_VOICE_DEV_ORG_ID=01900000-0000-7000-8000-000000000001

# ── demo bucket (hardcoded sf-voice-owned bucket; not per-org yet) ───────
# customer-bucket per-org auth is in core/TODO.md.
# SF_VOICE_DEMO_AWS_ACCESS_KEY_ID=
# SF_VOICE_DEMO_AWS_SECRET_ACCESS_KEY=
# SF_VOICE_DEMO_AWS_REGION=us-west-2
# SF_VOICE_DEMO_S3_BUCKET=sf-voice-demo-calls
# SF_VOICE_DEMO_S3_PREFIX=calls/
