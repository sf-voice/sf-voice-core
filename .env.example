# root-level env, loaded automatically by mise.toml when you cd into this
# repo (or run a `mise run …` task). copy to `.env` and tweak as needed.
#
# `.env` itself is gitignored — only this template is checked in.
#
# mise also loads `apps/<app>/.env` if present. those are reserved for
# *dynamic* values written by tasks (e.g. `mise run dev` writes the live
# ngrok URL into `apps/ellie_ai/.env`); put static config here.

# ── ports ────────────────────────────────────────────────────────────────
# each Phoenix app reads its own port from here so the two apps can run
# side-by-side from a single shell without colliding.
RESTO_BOOKING_APP_PORT=4000
ELLIE_AI_PORT=4001

# ── third-party keys (placeholders — fill in as ellie_ai comes online) ───
# OPENAI_API_KEY=sk-...
# TELNYX_API_KEY=KEY...
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-west-1
