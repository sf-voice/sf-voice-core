# root-level env, loaded automatically by mise.toml when you cd into this
# repo (or run a `mise run …` task). copy to `.env` and tweak as needed.
#
# `.env` itself is gitignored — only this template is checked in.
#
# `.env` is the single source of truth: every app + every task reads
# from here. dynamic values (e.g. NGROK_URL written by `mise run dev`)
# get appended to this same file so they survive across terminals.

# ── ports ────────────────────────────────────────────────────────────────
# each Phoenix app reads its own port from here so the two apps can run
# side-by-side from a single shell without colliding.
RESTO_BOOKING_APP_PORT=4000
ELLIE_AI_PORT=4321

# ── shared bearer between resto and ellie ────────────────────────────────
# resto's /api/* requires this; ellie sends it on every outbound call.
# anything non-empty works in dev — generate something random for prod.
INTERNAL_API_TOKEN=dev-internal-api-token-not-for-prod

# ── third-party keys (placeholders — fill in as ellie_ai comes online) ───
# OPENAI_API_KEY=sk-...
# TELNYX_API_KEY=KEY...
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-west-1
