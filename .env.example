# root-level env, loaded automatically by mise.toml when you cd into this
# repo (or run a `mise run …` task). copy to `.env` and tweak as needed.
#
# `.env` itself is gitignored — only this template is checked in.
#
# `.env` is the single source of truth: every app + every task reads
# from here. dynamic values (e.g. NGROK_URL written by `mise run dev`)
# get appended to this same file so they survive across terminals.

# ── ports ────────────────────────────────────────────────────────────────
# each Phoenix app reads its own port from here so the two apps can run
# side-by-side from a single shell without colliding.
RESTO_BOOKING_APP_PORT=4000
ELLIE_AI_PORT=4001

# ── shared bearer for every app↔app channel ──────────────────────────────
# canonical secret for service-to-service auth across the repo. used by:
#   - resto's `InternalAuth` plug on /api/*
#   - ellie's `InternalAuth` plug on /api/*
#   - ellie's `VadSocket.connect/3` (core/backend ↔ ellie WS handshake)
#   - ellie's `RestoClient` HTTP client (outbound from ellie → resto)
#   - core/backend's VAD client (outbound from core → ellie WS)
# any new service-to-service channel between apps/* and core/* must auth
# via this token, compared with `Plug.Crypto.secure_compare/2`.
# anything non-empty works in dev — generate something random for prod.
INTERNAL_API_TOKEN=dev-internal-api-token-not-for-prod

# ── third-party keys (placeholders — fill in as ellie_ai comes online) ───
# OPENAI_API_KEY=sk-...
# TELNYX_API_KEY=KEY...
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-west-1

# ── telnyx phone number (E.164, used by seeds.exs) ───────────────────────
# the single number ellie answers in dev. the seed assigns it to the
# canonical org (seasons-sf); the other seeded locations exist without
# a number for switcher demos and get one assigned manually via
# Settings → Phone & integrations as you provision more.
# PHONE_NUMBER=+18774980043

# ── core stack: rust api + dev data layer ────────────────────────────────
# DATABASE_URL is the canonical name sqlx/diesel/sea-orm read by default.
# format must match infra/dev/docker-compose.yml defaults (or whatever you
# override there via MYSQL_USER / MYSQL_PASSWORD / MYSQL_DATABASE).
DATABASE_URL=mysql://sf_voice:sf_voice@127.0.0.1:3306/sf_voice_dev

# duckdb is embedded (no server, no port). the rust api opens this file
# directly via the `duckdb` crate. relative paths resolve from the
# working dir cargo runs in — root of the repo for `mise run core:dev`.
# the file is created on first write; `mise run install` ensures the
# parent directory exists.
DUCKDB_PATH=./data/sf_voice.duckdb

# ── debugging product pipeline (phase C onwards) ─────────────────────────
# whisper (asr) — openai hosted, whisper-large-v3. embeddings reuse the
# same key (text-embedding-3-small).
# OPENAI_API_KEY=sk-...
#
# diarization endpoint — pyannote-3.1 via huggingface inference, or
# self-hosted equivalent. http POST audio, returns speaker turns.
# DIARIZE_URL=https://api-inference.huggingface.co/models/pyannote/speaker-diarization-3.1
#
# end-of-turn vad — phoenix channel on ellie, NOT http. core/backend's
# vad client opens a websocket to ellie's `/socket/vad` endpoint, auths
# with `INTERNAL_API_TOKEN`, and joins the `vad:*` topic. contract lives
# in apps/ellie_ai/lib/ellie_ai_web/channels/vad_channel.ex.
# VAD_WS_URL=ws://127.0.0.1:4001/socket/vad
#
# fixed org for legacy curl tests. real auth via signup/login landed in
# phase H and is what every authenticated request uses now; this var is
# only read by tools that pre-date the cookie session.
SF_VOICE_DEV_ORG_ID=01900000-0000-7000-8000-000000000001

# ── auth + secrets ──────────────────────────────────────────────────────
# encryption key for customer-provided secrets (currently: AWS secret
# access keys when they pick the "stored keys" bucket method).
# 32 bytes, hex or base64. generate with:
#   openssl rand -base64 32
# the dev value below is for local use ONLY — never reuse in prod.
SF_VOICE_SECRETS_KEY=dGVzdHRlc3R0ZXN0dGVzdHRlc3R0ZXN0dGVzdHRlc3RfZmI=

# set to true in prod so the session cookie has the `Secure` flag.
# leave unset / false in dev so http://localhost works.
# COOKIE_SECURE=true

# sf-voice's own AWS principal that customer roles trust. real prod
# value is the role ARN of the sf-voice ingest worker; dev placeholder
# is fine because no one's calling AssumeRole yet.
# SF_VOICE_AWS_PRINCIPAL=arn:aws:iam::111111111111:role/sf-voice-ingest

# public URL where the cloudformation template YAML is hosted. AWS
# console fetches this when the customer clicks the quick-create link,
# so it MUST be publicly reachable HTTPS. in dev, leave unset and use
# the "copy template manually" fallback in the UI.
# SF_VOICE_CFN_TEMPLATE_URL=https://app.sf-voice.sh/cfn/sf-voice-readonly.yaml

# dev escape hatch — when set, /api/org/bucket/role and /keys save
# WITHOUT hitting AWS to verify. lets you click through the onboarding
# flow on a laptop with no aws creds. NEVER set in prod.
# SF_VOICE_SKIP_AWS_VERIFY=1

# our AWS account creds used to AssumeRole into the customer's role.
# the standard aws-sdk env vars are honored (or use AWS_PROFILE, or an
# ec2 instance role in prod). only matters for the IAM-role bucket
# method; the access-keys method uses the customer's keys directly.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# ── demo bucket (hardcoded sf-voice-owned bucket; not per-org yet) ───────
# customer-bucket per-org auth is in core/TODO.md.
# SF_VOICE_DEMO_AWS_ACCESS_KEY_ID=
# SF_VOICE_DEMO_AWS_SECRET_ACCESS_KEY=
# SF_VOICE_DEMO_AWS_REGION=us-west-2
# SF_VOICE_DEMO_S3_BUCKET=sf-voice-demo-calls
# SF_VOICE_DEMO_S3_PREFIX=calls/

# ── ingest pipeline ──────────────────────────────────────────────────────
# our internal S3 bucket where downloaded / ingested files are stored
# before being handed to TwelveLabs. use the server's IAM role in prod;
# use AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY for local dev.
# INTERNAL_S3_BUCKET=sf-voice-media-internal
# INTERNAL_S3_REGION=us-east-1

# TwelveLabs API key for semantic video/audio search and embedding.
# create an index per customer org via the TwelveLabs dashboard and
# store the index_id in the `providers` table (linked via `org_providers`).
# TWELVELABS_API_KEY=tlk-...
