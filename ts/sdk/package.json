{
   "name": "@sf-voice/media",
   "version": "0.1.2",
   "description": "TypeScript SDK for the sf-voice media API",
   "license": "MIT",
   "author": "sf-voice",
   "type": "module",
   "main": "./dist/index.cjs",
   "module": "./dist/index.js",
   "types": "./dist/index.d.ts",
   "repository": {
      "url": "https://github.com/sf-voice/sf-voice-core"
   },
   "exports": {
      ".": {
         "import": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
         },
         "require": {
            "types": "./dist/index.d.cts",
            "default": "./dist/index.cjs"
         }
      }
   },
   "files": [
      "dist"
   ],
   "publishConfig": {
      "access": "public"
   },
   "scripts": {
      "build": "tsup",
      "dev": "tsup --watch",
      "typecheck": "tsc --noEmit"
   },
   "devDependencies": {
      "tsup": "^8.0.0",
      "typescript": "^5.4.0"
   }
}
