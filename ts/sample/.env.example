# required — your sf-voice API key
SF_VOICE_API_KEY=sfv_...

# sf-voice backend base URL (local dev default)
SF_VOICE_BASE_URL=http://localhost:8080

# port the demo UI listens on
PORT=3000

# URL that the sf-voice backend can reach to fetch uploaded/downloaded media.
# for local dev both servers are on the same machine so localhost works.
# if the backend is remote, set this to an ngrok or tunnel URL instead.
SELF_URL=http://localhost:3000
