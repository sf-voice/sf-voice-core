{
  "compilerOptions": {
    // target & output
    "lib": ["ESNext"],
    "target": "ESNext",
    "types": ["bun-types"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "moduleDetection": "force",

    // emit
    "outDir": "./dist",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,

    // best practices (kept from base tsconfig)
    "strict": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true
  },
  "include": ["."],
  "exclude": ["node_modules", "dist", "sample", "**/*.test.ts", "**/*.spec.ts"]
}
