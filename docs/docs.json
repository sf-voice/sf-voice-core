{
   "$schema": "https://mintlify.com/docs.json",
   "name": "San Francisco Voice Company",
   "theme": "linden",
   "colors": {
      "primary": "#5E6AD2",
      "light": "#8b93e8",
      "dark": "#4f5bd5"
   },
   "background": {
      "color": {
         "dark": "#0a0a0b"
      },
      "decoration": "grid"
   },
   "fonts": {
      "heading": {
         "family": "Geist",
         "weight": 600
      },
      "body": {
         "family": "Geist"
      }
   },
   "search": {
      "prompt": "Search docs..."
   },
   "logo": {
      "light": "/logos/light-logo.png",
      "dark": "/logos/dark-logo.png"
   },
   "favicon": "/logos/light-logo.png",
   "navbar": {
      "primary": {
         "type": "github",
         "href": "https://github.com/sf-voice/sf-voice-core"
      }
   },
   "footer": {
      "socials": {
         "github": "https://github.com/sf-voice/sf-voice-core",
         "discord": "https://discord.sf-voice.sh",
         "linkedin": "https://www.linkedin.com/company/sf-model/"
      }
   },
   "feedback": {
      "thumbsRating": true
   },
   "navigation": {
      "groups": [
         {
            "group": "Get Started",
            "pages": ["introduction", "quickstart", "how-it-works"]
         },
         {
            "group": "Platform",
            "pages": ["data-privacy"]
         },
         {
            "group": "SDKs",
            "pages": [
               "sdks/overview",
               "sdks/typescript",
               "sdks/python",
               "sdks/elixir",
               "sdks/java",
               "sdks/kotlin",
               "sdks/rust",
               "sdks/go"
            ]
         },
         {
            "group": "Examples",
            "pages": ["sdks/cpp"]
         }
      ]
   }
}
