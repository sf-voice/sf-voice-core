{
   "name": "fraud-prototype",
   "private": true,
   "version": "0.0.1",
   "description": "Phone-line fraud/scam detection prototype — TypeScript port. Standalone; does not depend on Ellie.",
   "type": "module",
   "engines": {
      "node": ">=22"
   },
   "bin": {
      "scammer": "./dist/cli/scammer.js"
   },
   "scripts": {
      "build": "bun build src/server.ts --outdir dist --target node --packages external && bun build src/cli/scammer.ts --outdir dist/cli --target node --packages external",
      "typecheck": "tsgo --project tsconfig.json --noEmit",
      "dev": "bun --env-file=../../.env --watch --experimental-strip-types --no-warnings src/server.ts",
      "start": "node dist/server.js",
      "scammer": "node --env-file=../../.env --experimental-strip-types --no-warnings src/cli/scammer.ts",
      "test": "vitest run"
   },
   "dependencies": {
      "@fastify/websocket": "^11.0.2",
      "fastify": "^5.2.1",
      "openai": "^4.77.0",
      "ws": "^8.18.0"
   },
   "devDependencies": {
      "@types/node": "^22.10.7",
      "@types/ws": "^8.5.13",
      "@typescript/native-preview": "^7.0.0-dev.20251001.1",
      "typescript": "^5.7.3",
      "vitest": "^3.0.5"
   }
}
