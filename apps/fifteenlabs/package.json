{
  "name": "fifteenlabs-ts",
  "private": true,
  "version": "0.0.1",
  "description": "sf-voice media SDK demo — Fastify server + search UI",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "bun --env-file=.env --watch --experimental-strip-types --no-warnings src/index.ts",
    "build": "tsc --build",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/static": "^8.0.0",
    "@sf-voice/media": "workspace:*",
    "fastify": "^5.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.4.0"
  }
}
