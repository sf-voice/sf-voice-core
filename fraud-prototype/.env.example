# Telnyx
TELNYX_API_KEY=
TELNYX_CONNECTION_ID=
ELLIE_TELNYX_FROM=+15555550100

# OpenAI (Realtime API + chat completions for the fraud classifier)
OPENAI_API_KEY=

# the operator phone — both the scammer's target AND the alert dial-back number.
FRAUD_ALERT_PHONE_E164=+15551234567

# public URL that Telnyx hits — usually an ngrok URL in dev.
PUBLIC_URL=https://your-ngrok-id.ngrok.app

# HTTP port the prototype listens on.
PORT=4000

# fraud detector threshold (default 0.7)
FRAUD_THRESHOLD=0.7

# OpenAI Realtime model + voice (per-script voice overrides this).
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview
OPENAI_REALTIME_VOICE=alloy

# fraud classifier model (cheap is fine).
FRAUD_CLASSIFIER_MODEL=gpt-4o-mini

# modular backend stubs (not implemented in v1)
KUGEL_AUDIO_API_KEY=
KUGEL_AUDIO_ENDPOINT=
ELEVENLABS_API_KEY=
ANTHROPIC_API_KEY=
